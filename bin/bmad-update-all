#!/usr/bin/env bash
# bmad-update-all - refresh BMAD @next in every repo that has it installed.
#
# Usage:
#   bmad-update-all             # run quick-update in every repo with _bmad/
#   bmad-update-all --dry-run   # list repos + versions, do nothing
#   bmad-update-all --list      # alias for --dry-run
#   bmad-update-all --commit    # update AND commit, PR, squash-merge, delete branch
#
# Scans: ~/crown, ~/personal, ~/confelicity
# A directory is considered a BMAD install if it contains a _bmad/ subdirectory.
# quick-update preserves each repo's module set and prior install answers.
#
# Skip list:
#   Repos listed in etc/bmad-update-all.skip (relative to this script) are
#   ignored. Override the file location with BMAD_UPDATE_SKIP_FILE=/path.
#   Format: one repo path per line, relative to $HOME (e.g. "crown/crown-knowledge").
#   Blank lines and lines starting with # are ignored.
#
# --commit flow per repo (skipped with reasons if any preflight fails):
#   1. Preflight: on main, in sync with origin/main, not detached HEAD.
#   2. Run quick-update.
#   3. Scope changes to _bmad/ + .claude/skills/{bmad,wds,gds}-* (ignores
#      non-BMAD skills like gstack, browse, etc.)
#   4. If no BMAD changes: skip.
#   5. Create branch bmad-update-<version> from main, stage, commit, push.
#      <version> is read from _bmad/core/config.yaml after install (always @next).
#   6. gh pr create --base main, gh pr merge --squash --delete-branch.
#   7. git pull main (fast-forward).

set -u

ROOTS=("$HOME/crown" "$HOME/personal" "$HOME/confelicity")
COMMIT_BODY="Automated BMAD quick-update via \`~/bin/bmad-update-all --commit\`. Preserves existing module set."

# Read installed BMAD version from a repo's _bmad/core/config.yaml.
# Echoes the version string (e.g. "6.3.1-next.20") or "unknown" if unreadable.
read_bmad_version() {
  local cfg="$1/_bmad/core/config.yaml"
  [ -f "$cfg" ] || { echo "unknown"; return; }
  local v
  v=$(grep -E "^# Version:" "$cfg" | head -1 | sed 's/^# Version:[[:space:]]*//' | tr -d ' ')
  [ -n "$v" ] && echo "$v" || echo "unknown"
}

# Resolve this script's real directory (follows symlinks; macOS-portable; no readlink -f).
SCRIPT_PATH="$0"
while [ -L "$SCRIPT_PATH" ]; do
  link_target="$(readlink "$SCRIPT_PATH")"
  case "$link_target" in
    /*) SCRIPT_PATH="$link_target" ;;
    *)  SCRIPT_PATH="$(dirname "$SCRIPT_PATH")/$link_target" ;;
  esac
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
SKIP_FILE="${BMAD_UPDATE_SKIP_FILE:-$SCRIPT_DIR/../etc/bmad-update-all.skip}"

MODE="update"
case "${1:-}" in
  --dry-run|--list) MODE="list" ;;
  --commit)         MODE="commit" ;;
  -h|--help)
    sed -n '2,29p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
    ;;
  "") ;;
  *)
    echo "unknown argument: $1" >&2
    echo "try: bmad-update-all --help" >&2
    exit 2
    ;;
esac

# ──────────────────────────────────────────────────────────────────────────
# load skip list
# ──────────────────────────────────────────────────────────────────────────
SKIPS=()
if [ -f "$SKIP_FILE" ]; then
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%%#*}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [ -z "$line" ] && continue
    SKIPS+=("$line")
  done < "$SKIP_FILE"
fi

is_skipped() {
  local repo_rel="${1#$HOME/}"
  for s in "${SKIPS[@]:-}"; do
    [ -z "$s" ] && continue
    [ "$s" = "$repo_rel" ] && return 0
  done
  return 1
}

# ──────────────────────────────────────────────────────────────────────────
# discover BMAD installs
# ──────────────────────────────────────────────────────────────────────────
found=()
skipped_by_config=()
for root in "${ROOTS[@]}"; do
  [ -d "$root" ] || continue
  for repo in "$root"/*/; do
    repo="${repo%/}"
    [ -d "${repo}/_bmad" ] || continue
    if is_skipped "$repo"; then
      skipped_by_config+=("${repo#$HOME/}")
      continue
    fi
    found+=("$repo")
  done
done

if [ "${#found[@]}" -eq 0 ]; then
  echo "no BMAD installs found under: ${ROOTS[*]}"
  if [ "${#skipped_by_config[@]}" -gt 0 ]; then
    echo "(skip list excluded: ${skipped_by_config[*]})"
  fi
  exit 0
fi

echo "Found ${#found[@]} BMAD install(s):"
for r in "${found[@]}"; do
  version=$(read_bmad_version "$r")
  printf "  %-52s %s\n" "${r#$HOME/}" "$version"
done
if [ "${#skipped_by_config[@]}" -gt 0 ]; then
  echo ""
  echo "Skipped by config (${SKIP_FILE#$HOME/~}):"
  for r in "${skipped_by_config[@]}"; do printf "  %s\n" "$r"; done
fi
echo ""

if [ "$MODE" = "list" ]; then
  echo "(dry run — no changes made)"
  exit 0
fi

# ──────────────────────────────────────────────────────────────────────────
# helpers (used in --commit mode)
# ──────────────────────────────────────────────────────────────────────────
preflight() {
  local repo="$1"
  # must have a main branch
  if ! git -C "$repo" show-ref --verify --quiet refs/heads/main; then
    echo "SKIP: no local main branch"; return 1
  fi
  # must have at least one commit
  if ! git -C "$repo" rev-parse HEAD >/dev/null 2>&1; then
    echo "SKIP: repo has no commits"; return 1
  fi
  # must be on main (no detached HEAD, no feature branch with unpushed work)
  local current="$(git -C "$repo" branch --show-current 2>/dev/null)"
  if [ "$current" != "main" ]; then
    echo "SKIP: currently on '${current:-detached HEAD}', not main"; return 1
  fi
  # must be in sync with origin/main
  git -C "$repo" fetch origin main >/dev/null 2>&1
  local ahead behind
  ahead=$(git -C "$repo" rev-list --count origin/main..main 2>/dev/null)
  behind=$(git -C "$repo" rev-list --count main..origin/main 2>/dev/null)
  if [ "$ahead" != "0" ] || [ "$behind" != "0" ]; then
    echo "SKIP: local main diverged from origin (ahead=$ahead behind=$behind)"; return 1
  fi
  # _bmad must not be gitignored (if it is, update has no effect on tracked state)
  if git -C "$repo" check-ignore -q _bmad 2>/dev/null; then
    echo "SKIP: _bmad/ is gitignored in this repo"; return 1
  fi
  return 0
}

quick_update() {
  local repo="$1"
  npx --yes bmad-method@next install \
    --directory "$repo" \
    --action quick-update \
    -y >/dev/null 2>&1
}

bmad_pr() {
  local repo="$1"
  local branch="$2"
  local commit_title="$3"
  cd "$repo" || return 1

  # clean up any stale branch from a prior failed run
  git branch -D "$branch" >/dev/null 2>&1 || true
  git push origin --delete "$branch" >/dev/null 2>&1 || true
  git checkout -b "$branch" main >/dev/null 2>&1

  # collect BMAD-scoped paths from current working-tree changes (array-based
  # to avoid shell glob / word-splitting pitfalls; covers adds, mods, deletes)
  local -a paths=()
  while IFS= read -r p; do
    [ -n "$p" ] && paths+=("$p")
  done < <(git status --porcelain | awk '{print substr($0, 4)}' | \
           grep -E "^(_bmad/|\.claude/skills/(bmad|wds|gds)-)")

  if [ "${#paths[@]}" -eq 0 ]; then
    echo "no BMAD-scoped changes"
    git checkout main >/dev/null 2>&1
    git branch -D "$branch" >/dev/null 2>&1
    return 0
  fi

  git add -A -- "${paths[@]}"
  local count
  count=$(git diff --cached --numstat | wc -l | tr -d ' ')
  echo "staging $count files, creating PR ..."

  git commit -m "$commit_title" >/dev/null
  git push -u origin "$branch" >/dev/null 2>&1
  local pr_url
  pr_url=$(gh pr create --base main --head "$branch" \
    --title "$commit_title" --body "$COMMIT_BODY" 2>/dev/null | tail -1)

  if [ -z "$pr_url" ] || [[ "$pr_url" != https://* ]]; then
    echo "ERROR: PR create failed (url='$pr_url')"
    return 1
  fi

  if gh pr merge --squash --delete-branch "$pr_url" >/dev/null 2>&1; then
    echo "merged: $pr_url"
  else
    echo "ERROR: squash-merge failed for $pr_url"
    return 1
  fi

  git checkout main >/dev/null 2>&1
  git pull --ff-only >/dev/null 2>&1
  git branch -D "$branch" >/dev/null 2>&1 || true
  return 0
}

# ──────────────────────────────────────────────────────────────────────────
# run the chosen mode
# ──────────────────────────────────────────────────────────────────────────
succeeded=()
skipped=()
failed=()

for repo in "${found[@]}"; do
  echo ""
  echo "========================================================================"
  echo " ${repo#$HOME/}"
  echo "========================================================================"

  if [ "$MODE" = "commit" ]; then
    if ! msg=$(preflight "$repo"); then
      echo "  $msg"
      skipped+=("${repo#$HOME/}: ${msg#SKIP: }")
      continue
    fi
    if ! quick_update "$repo"; then
      echo "  ERROR: quick-update failed"
      failed+=("${repo#$HOME/}: quick-update")
      continue
    fi
    version=$(read_bmad_version "$repo")
    branch="bmad-update-${version}"
    commit_title="Update BMAD to v${version}"
    if bmad_pr "$repo" "$branch" "$commit_title"; then
      succeeded+=("${repo#$HOME/}")
    else
      failed+=("${repo#$HOME/}: PR flow")
    fi
  else
    # plain --update mode
    if quick_update "$repo"; then
      succeeded+=("${repo#$HOME/}")
    else
      failed+=("${repo#$HOME/}: quick-update")
    fi
  fi
done

# ──────────────────────────────────────────────────────────────────────────
# summary
# ──────────────────────────────────────────────────────────────────────────
echo ""
echo "========================================================================"
echo " Summary"
echo "========================================================================"
echo "  Succeeded: ${#succeeded[@]} / ${#found[@]}"
if [ "${#skipped[@]}" -gt 0 ]; then
  echo "  Skipped:"
  for r in "${skipped[@]}"; do echo "    - $r"; done
fi
if [ "${#failed[@]}" -gt 0 ]; then
  echo "  Failed:"
  for r in "${failed[@]}"; do echo "    - $r"; done
  exit 1
fi
